{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Current Test File",
      "type": "node",
      "request": "launch",
      "program": "${file}",
      "runtimeArgs": [
        "--experimental-strip-types",
        "--test",
        "--inspect-brk=0"
      ],
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "group": "Node.js Test",
        "order": 1
      }
    },
    {
      "name": "Debug solution.test.ts",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/solution.test.ts",
      "runtimeArgs": [
        "--experimental-strip-types",
        "--test",
        "--inspect-brk=0"
      ],
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "group": "Node.js Test",
        "order": 2
      }
    }
  ]
}
